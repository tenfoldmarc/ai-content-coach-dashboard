# ─────────────────────────────────────────────────────────────
# AI Content Coach — Environment Variables
# ─────────────────────────────────────────────────────────────
# 1. Copy this file: cp .env.example .env
# 2. Fill in your tokens below
# 3. .env is gitignored — never committed
# ─────────────────────────────────────────────────────────────

# Required: Apify token for Instagram scraping
# Get it free at apify.com → Settings → API tokens
APIFY_TOKEN=apify_api_YOUR_TOKEN_HERE

# Optional: Only needed if you chose "API key" during setup
# Claude Code OAuth users (claude.ai subscription) can skip this
# Get it at console.anthropic.com → API Keys
# ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
